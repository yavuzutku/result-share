# ─── Server ───────────────────────────────────────────────
PORT=3001

# Full public URL of this server (no trailing slash)
# Used to build shareUrl and OG image URLs
BASE_URL=https://almancapratik.com

# Allowed CORS origins (comma-separated or *)
ALLOWED_ORIGINS=https://almancapratik.com

# ─── Firebase Admin SDK ────────────────────────────────────
# Option A: path to your service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B: paste the JSON as a single-line string (for env-variable deployments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Optional: In-memory / file fallback ──────────────────
# If Firebase is NOT configured, results are stored in ./data/results.json
# Set to "file" to force file-based store even if Firebase is present
# STORE_BACKEND=file
